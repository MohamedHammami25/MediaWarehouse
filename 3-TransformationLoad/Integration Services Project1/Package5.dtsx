            <component
              refId="Package\Transformation\Trier"
              componentClassID="Microsoft.Sort"
              contactInfo="Trier;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; Tous droits réservés; http://www.microsoft.com/sql/support;1"
              description="Trie les données d'entrée en ordre croissant ou décroissant lorsque le tri ne peut pas être effectué à la source. Par exemple, triez les données de vente par 'id de client' avant leur enregistrement dans un fichier plat et leur diffusion dans un autre service. Remarque : nous ne recommandons pas cette transformation dans le cas de flux de données volumineux."
              name="Trier"
              version="1">
              <properties>
                <property
                  dataType="System.Boolean"
                  description="Indique si la transformation de tri supprime les lignes comportant des valeurs de tri en double."
                  name="EliminateDuplicates">true</property>
                <property
                  dataType="System.Int32"
                  description="Spécifie le nombre maximal de threads à utiliser pour le tri."
                  expressionType="Notify"
                  name="MaximumThreads">-1</property>
              </properties>
              <inputs>
                <input
                  refId="Package\Transformation\Trier.Inputs[Entrée de tri]"
                  name="Entrée de tri">
                  <inputColumns>
                    <inputColumn
                      refId="Package\Transformation\Trier.Inputs[Entrée de tri].Columns[LanguageCode]"
                      cachedDataType="wstr"
                      cachedLength="10"
                      cachedName="LanguageCode"
                      lineageId="Package\Transformation\Transformation scriptée.Outputs[Sortie 0].Columns[LanguageCode]">
                      <properties>
                        <property
                          dataType="System.Int32"
                          description="Spécifie les options de comparaison pour les données caractères."
                          name="NewComparisonFlags">0</property>
                        <property
                          dataType="System.Int32"
                          description="Spécifie l'ordre de tri de la colonne."
                          name="NewSortKeyPosition">1</property>
                      </properties>
                    </inputColumn>
                  </inputColumns>
                  <externalMetadataColumns />
                </input>
              </inputs>
              <outputs>
                <output
                  refId="Package\Transformation\Trier.Outputs[Sortie de tri]"
                  isSorted="true"
                  name="Sortie de tri">
                  <outputColumns>
                    <outputColumn
                      refId="Package\Transformation\Trier.Outputs[Sortie de tri].Columns[LanguageCode]"
                      dataType="wstr"
                      length="10"
                      lineageId="Package\Transformation\Trier.Outputs[Sortie de tri].Columns[LanguageCode]"
                      name="LanguageCode"
                      sortKeyPosition="1">
                      <properties>
                        <property
                          containsID="true"
